{"openapi": "3.1.0", "info": {"title": "AI Brief Decoder Lite", "description": "FastAPI service for decoding and analyzing client briefs", "version": "0.1.0"}, "paths": {"/api/health": {"get": {"tags": ["System"], "summary": "Health Check", "description": "Health check endpoint to verify backend service status.", "operationId": "health_check_api_health_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HealthCheckState"}}}}}}}, "/api/v1/briefs": {"post": {"tags": ["Briefs"], "summary": "Decode Brief", "description": "Creates a brief decoding run and triggers the analysis in the background.", "operationId": "decode_brief_api_v1_briefs_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/BriefRequest"}}}, "required": true}, "responses": {"202": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BriefResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/briefs/{brief_id}": {"get": {"tags": ["Briefs"], "summary": "Get Brief", "description": "Gets the details and analysis results of a specific brief.", "operationId": "get_brief_api_v1_briefs__brief_id__get", "parameters": [{"name": "brief_id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid", "title": "Brief Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BriefResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}}, "components": {"schemas": {"BriefAnalysisResponse": {"properties": {"project_type": {"type": "string", "title": "Project Type", "description": "Main type or domain of the project"}, "budget_info": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Budget Info", "description": "Budget description, limits, or constraints mentioned in the brief"}, "deadline_info": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Deadline Info", "description": "Deadline, milestones, or timeline constraints mentioned in the brief"}, "key_requirements": {"items": {"type": "string"}, "type": "array", "title": "Key Requirements", "description": "List of key requirements extracted from the brief"}, "risks": {"items": {"$ref": "#/components/schemas/RiskItem"}, "type": "array", "title": "Risks", "description": "List of identified risks with their severity and mitigation strategies"}}, "type": "object", "required": ["project_type"], "title": "BriefAnalysisResponse", "description": "The structured output format returned by the AI provider."}, "BriefRequest": {"properties": {"text": {"type": "string", "minLength": 10, "title": "Text", "description": "Raw brief text to analyze", "examples": ["We need a mobile app for food delivery. Budget is 15k USD. Deadline: 3 months."]}}, "type": "object", "required": ["text"], "title": "BriefRequest", "description": "Input payload for a brief analysis request."}, "BriefResponse": {"properties": {"id": {"type": "string", "format": "uuid", "title": "Id"}, "status": {"$ref": "#/components/schemas/BriefStatus"}, "input_text": {"type": "string", "title": "Input Text"}, "structured_result": {"anyOf": [{"$ref": "#/components/schemas/BriefAnalysisResponse"}, {"type": "null"}]}, "error_code": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Error Code"}, "error_message": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Error Message"}, "started_at": {"anyOf": [{"type": "string", "format": "date-time"}, {"type": "null"}], "title": "Started At"}, "finished_at": {"anyOf": [{"type": "string", "format": "date-time"}, {"type": "null"}], "title": "Finished At"}, "created_at": {"type": "string", "format": "date-time", "title": "Created At"}, "updated_at": {"type": "string", "format": "date-time", "title": "Updated At"}}, "type": "object", "required": ["id", "status", "input_text", "created_at", "updated_at"], "title": "BriefResponse", "description": "Output details of a brief analysis."}, "BriefStatus": {"type": "string", "enum": ["pending", "processing", "completed", "failed"], "title": "BriefStatus"}, "HTTPValidationError": {"properties": {"detail": {"items": {"$ref": "#/components/schemas/ValidationError"}, "type": "array", "title": "Detail"}}, "type": "object", "title": "HTTPValidationError"}, "HealthCheckState": {"properties": {"Status": {"type": "string", "const": "Ok", "title": "Status"}}, "type": "object", "required": ["Status"], "title": "HealthCheckState"}, "RiskItem": {"properties": {"description": {"type": "string", "title": "Description", "description": "Description of the identified risk"}, "severity": {"$ref": "#/components/schemas/SeverityEnum", "description": "Severity level of the risk"}, "mitigation": {"type": "string", "title": "Mitigation", "description": "Suggested way to mitigate or minimize the risk"}}, "type": "object", "required": ["description", "severity", "mitigation"], "title": "RiskItem"}, "SeverityEnum": {"type": "string", "enum": ["low", "medium", "high"], "title": "SeverityEnum"}, "ValidationError": {"properties": {"loc": {"items": {"anyOf": [{"type": "string"}, {"type": "integer"}]}, "type": "array", "title": "Location"}, "msg": {"type": "string", "title": "Message"}, "type": {"type": "string", "title": "Error Type"}}, "type": "object", "required": ["loc", "msg", "type"], "title": "ValidationError"}}}}
